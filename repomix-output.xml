<file path="src/renderer/src/App.vue">
<script setup lang="ts">
import { ref, onMounted } from 'vue'

const logInput = ref('')
const inputRef = ref<HTMLInputElement | null>(null)

// 窗口重新获取焦点时，自动聚焦输入框
onMounted(() => {
  inputRef.value?.focus()
  window.addEventListener('focus', () => {
    inputRef.value?.focus()
  })
})

const submitLog = () => {
  const text = logInput.value.trim()
  if (!text) return

  // 通过预加载脚本暴露的 IPC 接口，将数据发送给主进程
  window.electron.ipcRenderer.send('save-log', text)

  // 提交后清空输入框内容并隐藏窗口（可选体验优化）
  logInput.value = ''
}
</script>

<template>
  <div class="h-screen w-screen bg-neutral-950 flex flex-col items-center justify-center font-sans text-neutral-200 select-none overflow-hidden">
    
    <h1 class="text-5xl font-extrabold tracking-tight bg-linear-to-r from-cyan-400 to-blue-600 bg-clip-text text-transparent mb-12 drop-shadow-lg">
      AstraSync
    </h1>

    <div class="w-full max-w-2xl px-6 relative">
      <input
        ref="inputRef"
        v-model="logInput"
        @keyup.enter="submitLog"
        type="text"
        placeholder="输入你的活动轨迹... (如: 阅读安全文献 45m)"
        class="w-full bg-neutral-900/60 border border-neutral-700/50 rounded-2xl px-8 py-5 text-xl text-neutral-100 placeholder-neutral-600 focus:outline-none focus:ring-2 focus:ring-cyan-500/50 backdrop-blur-xl transition-all shadow-2xl"
      />
      
      <div class="flex justify-between items-center mt-4 px-2 text-neutral-500 text-xs tracking-widest uppercase font-semibold">
        <span>Natural Language Input</span>
        <span>Press <kbd class="bg-neutral-800 px-2 py-1 rounded text-neutral-400">Enter</kbd> to execute</span>
      </div>
